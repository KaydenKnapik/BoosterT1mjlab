<mujoco model="ball">
  <worldbody>
    <!-- Soccer ball: size 5, radius=0.11m, mass=0.45kg -->
    <!-- group=1: keeps ball out of terrain raycasts (which only scan group 0) -->
    <body name="ball" pos="0 0 0.11">
      <!-- damping=0.005: minimal viscous drag so ball rolls far after kick -->
      <joint type="free" name="ball_freejoint" damping="0.005"/>
      <!-- I = 2/5 * m * r^2 for solid sphere approximation -->
      <inertial mass="0.45" pos="0 0 0" diaginertia="0.00218 0.00218 0.00218"/>
      <!-- friction = [slide, torsional, rolling] -->
      <geom name="ball_geom"
            type="sphere"
            size="0.11"
            group="1"
            rgba="1 0.9 0 1"
            condim="6"
            friction="0.2 0.005 0.001"
            contype="1"
            conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
